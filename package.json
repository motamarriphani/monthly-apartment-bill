{
  "name": "monthly-apartment-bill",
  "version": "1.0.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "web": "expo start --web",
    "build:web": "expo export --platform web --clear",
    "deploy:web": "npm run build:web && node -e \"require('fs').writeFileSync('dist/.nojekyll','')\" && gh-pages -d dist -b gh-pages --dotfiles"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.6.0",
    "@react-native-picker/picker": "2.11.4",
    "expo": "^55.0.4",
    "expo-media-library": "~55.0.9",
    "expo-updates": "~55.0.12",
    "fbjs": "^3.0.5",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-view-shot": "4.0.3",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "babel-preset-expo": "~55.0.8",
    "gh-pages": "^6.3.0"
  }
}
